{
  "$schema": "https://raw.githubusercontent.com/nicbarker/tauri/refs/heads/dev/crates/tauri-schema-generator/schemas/config.schema.json",
  "productName": "Native Agents",
  "version": "0.1.0",
  "identifier": "com.native-agents.app",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../frontend"
  },
  "app": {
    "windows": [
      {
        "title": "Native Agents",
        "width": 800,
        "height": 600,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "python-env/**/*",
      "../models/**/*"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
